{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "lib": ["es2022"],
    "types": ["node"],
    "typeRoots": ["node_modules/@types"],
    "moduleResolution": "node16",
    "module": "node16",
    "declaration": true
  }
}
