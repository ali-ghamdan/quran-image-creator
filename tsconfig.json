{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2015",
    "moduleDetection": "force",
    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"], // Added DOM support here
    "types": ["node"],
    "typeRoots": ["node_modules/@types"],
    "moduleResolution": "node16",
    "module": "node16",
    "declaration": true,
    "sourceMap": true
  }
}
